# ==== Copy to .env and fill in real values. Never commit .env. ====

# Database (PostgreSQL + pgvector)
DB_NAME=makit
DB_USER=makit_user
DB_PASSWORD=change-me-locally

# JWT (must be >= 32 chars; generate with: openssl rand -base64 48)
JWT_SECRET=change-this-to-a-secure-random-256bit-or-longer-string

# AWS (Bedrock + S3)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=makit-assets

# Optional: Redis (defaults: redis:6379 inside the compose network)
REDIS_HOST=redis
REDIS_PORT=6379

# CORS — comma-separated origin allowlist (frontend host(s))
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000,http://localhost:5173
